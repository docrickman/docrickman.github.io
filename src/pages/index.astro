---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 2.5em;
			}
			h2 {
				font-size: 1.75em;
			}
			h2::after {
				content: '';
				display: block;
				width: 2.5rem;
				height: 4px;
				margin-top: 0.35rem;
				border-radius: 2px;
				background: linear-gradient(90deg, var(--accent), var(--accent-2));
			}
			.entry-list {
				list-style: none;
				margin: 0.75em 0 2.5em 0;
				padding: 0;
			}
			.entry-list li {
				margin-bottom: 1.25em;
				padding-left: 0.85em;
				border-left: 3px solid rgb(var(--gray-light));
				transition: border-color 0.15s ease;
			}
			.entry-list li:hover {
				border-left-color: var(--accent);
			}
			.entry-list a {
				text-decoration: none;
			}
			.entry-list h3 {
				margin: 0;
				font-size: 1.25em;
				color: rgb(var(--black));
			}
			.entry-list a:hover h3 {
				color: var(--accent);
			}
			.entry-list .date {
				margin: 0;
				font-size: 0.85em;
				color: var(--accent-2);
			}
			.entry-list p.desc {
				margin: 0.15em 0 0 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Jonah Weber</h1>
				<p>
					I do IT at TerraPower, a nuclear energy R&amp;D company. The title says Tier 2
					support. The work is Active Directory and M365 administration, PowerShell tooling
					for a team that didn't have version control until I set it up, and keeping lab
					computing alive: LabVIEW rigs, cRIO controllers, machines that can't be patched
					mid-experiment.
				</p>
				<p>
					Most of that work lives in a locked-down government-cloud tenant and can't be shown.
					This site holds what can: personal projects, generic reimplementations of the work
					patterns, and write-ups of problems that were interesting to diagnose.
				</p>
				<p>
					With my friend ATPot I also run a heavily modded Project Zomboid server. It turned
					out to be a better systems lab than anything I could've enrolled in.
				</p>
			</section>
			<section>
				<h2>Projects</h2>
				<ul class="entry-list">
					{
						projects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`}>
									<h3>{project.data.title}</h3>
									<p class="date">
										<FormattedDate date={project.data.pubDate} />
									</p>
									<p class="desc">{project.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<section>
				<h2>Write-ups</h2>
				<ul class="entry-list">
					{
						notes.map((note) => (
							<li>
								<a href={`/notes/${note.id}/`}>
									<h3>{note.data.title}</h3>
									<p class="date">
										<FormattedDate date={note.data.pubDate} />
									</p>
									<p class="desc">{note.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
